<?xml version="1.0" encoding="utf-8"?>
<!-- Airlock stores nothing worth backing up; disable cloud/device transfer entirely. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
